{
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/parse-text.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/extract-text.ts": {
      "maxDuration": 60,
      "memory": 2048,
      "includeFiles": "node_modules/pdfjs-dist/legacy/build/pdf.worker.mjs"
    },
    "api/parse-statement.ts": {
      "maxDuration": 60,
      "memory": 2048,
      "includeFiles": "node_modules/pdfjs-dist/legacy/build/pdf.worker.mjs"
    }
  }
}
